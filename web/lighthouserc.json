{
	"$schema": "https://raw.githubusercontent.com/GoogleChrome/lighthouse-ci/main/packages/utils/src/lighthouse-schema.json",
	"ci": {
		"collect": {
			"startServerCommand": "node build/index.js",
			"startServerReadyPattern": "Listening on",
			"startServerReadyTimeout": 20000,
			"url": ["http://127.0.0.1:3000/", "http://127.0.0.1:3000/datasets/hospital-directory"],
			"numberOfRuns": 3,
			"settings": {
				"preset": "desktop"
			}
		},
		"assert": {
			"assertions": {
				"categories:performance": ["error", { "minScore": 0.85 }],
				"categories:accessibility": ["error", { "minScore": 0.95 }],
				"categories:best-practices": ["error", { "minScore": 0.9 }],
				"categories:seo": ["error", { "minScore": 0.9 }]
			}
		},
		"upload": {
			"target": "filesystem",
			"outputDir": "./lhci-reports",
			"reportFilenamePattern": "%%PATHNAME%%-%%DATETIME%%-report.%%EXTENSION%%"
		}
	}
}
