#!/usr/bin/env bash
#
# commit-msg hook — enforce Conventional Commits + project-specific rules.
# Activate locally with:  git config core.hooksPath .githooks
#                          (or run scripts/setup.sh)
#
# Rules:
#   1. First line matches:  <type>(<scope>)?!?: <subject>( (#<sub-issue-id>))?
#   2. <type> ∈ feat|fix|docs|refactor|chore|test|perf|build|ci|style|revert
#   3. <scope> ∈ mcp|backend|frontend|etl|infra|docs|i18n|community|security|deps
#      (optional; if present must be from the list above)
#   4. First line ≤ 72 chars
#   5. If second line exists, it must be blank
#   6. Lines starting with `#` are ignored (git comments)
#
# Exit non-zero on violation; commit is aborted.

set -euo pipefail

COMMIT_MSG_FILE="$1"

# Read message stripping comment lines and the diff-template (after the scissor).
# Bash 3.2-compatible (macOS default) — no mapfile, no negative index.
LINES=()
while IFS= read -r line; do
  LINES+=( "$line" )
done < <(grep -v '^#' "$COMMIT_MSG_FILE" | sed '/^------------------------ >8 ------------------------$/,$d')

# Trim trailing empty lines
while [ "${#LINES[@]}" -gt 0 ]; do
  last_idx=$(( ${#LINES[@]} - 1 ))
  last="${LINES[$last_idx]}"
  if [ -z "${last// /}" ]; then
    unset "LINES[$last_idx]"
  else
    break
  fi
done

if [ "${#LINES[@]}" -eq 0 ] || [ -z "${LINES[0]// /}" ]; then
  echo "✗ commit-msg: message is empty." >&2
  exit 1
fi

FIRST="${LINES[0]}"

# Allow merge / revert auto-messages from git itself
if [[ "$FIRST" =~ ^Merge\ (branch|remote-tracking|pull\ request) ]]; then exit 0; fi
if [[ "$FIRST" =~ ^Revert\  ]]; then exit 0; fi
if [[ "$FIRST" =~ ^fixup! || "$FIRST" =~ ^squash! ]]; then exit 0; fi

TYPE_RE='(feat|fix|docs|refactor|chore|test|perf|build|ci|style|revert)'
SCOPE_RE='(mcp|backend|frontend|etl|infra|docs|i18n|community|security|deps)'
# Subject regex (POSIX ERE — no lookahead, so we use negated char classes):
#   - 1+ chars total
#   - first char NOT uppercase AND (when it is also the last char) NOT a period
#   - last char NOT a period
#   - periods allowed elsewhere (e.g. trailing "(#0.1)" issue ref outside this group)
# This mirrors the GHA pattern `^(?![A-Z]).*[^.]$` in pr-title.yml so local
# commits and PR titles enforce the same length rule.
SUBJECT_RE='[^A-Z.](.{0,99}[^.])?'
ISSUE_RE='( \(#[0-9]+(\.[0-9]+|[a-z]\.[0-9]+)?\))?'

# Full regex (POSIX ERE, used via [[ =~ ]])
PATTERN="^${TYPE_RE}(\(${SCOPE_RE}\))?!?: ${SUBJECT_RE}${ISSUE_RE}$"

if ! [[ "$FIRST" =~ $PATTERN ]]; then
  cat >&2 <<EOF
✗ commit-msg: subject does not match Conventional Commits.

  Expected: <type>(<scope>)?!?: <subject> (#<sub-issue-id>)?
  Got:      $FIRST

  Allowed types : feat fix docs refactor chore test perf build ci style revert
  Allowed scopes: mcp backend frontend etl infra docs i18n community security deps
  Subject       : imperative, lowercase, no period, ≤ 72 chars

  Examples:
    feat(mcp): implement list_domains tool (#1.3)
    fix(etl): handle ETag mismatch on data.gov.tw (#1.4)
    chore(deps): bump axum 0.8.7 → 0.8.8
    refactor(backend)!: change query_rows return shape (#1.7)

  See CLAUDE.md or CONTRIBUTING.md for the full format spec.
EOF
  exit 1
fi

# Length check (use UTF-8 char count, since 中文 in scope counts differently)
LEN=$(printf '%s' "$FIRST" | wc -m | tr -d ' ')
if (( LEN > 72 )); then
  echo "✗ commit-msg: subject is ${LEN} chars (max 72)." >&2
  echo "  $FIRST" >&2
  exit 1
fi

# Blank line check (line 2 if it exists must be blank)
if [[ "${#LINES[@]}" -ge 2 && -n "${LINES[1]// /}" ]]; then
  echo "✗ commit-msg: line 2 must be blank (got: '${LINES[1]}')." >&2
  exit 1
fi

# Soft-warn on missing DCO sign-off (do not block; let CI decide)
if ! grep -qE '^Signed-off-by: .+ <.+@.+>$' "$COMMIT_MSG_FILE"; then
  echo "⚠ commit-msg: no Signed-off-by trailer (use \`git commit -s\` to add DCO sign-off)." >&2
fi

exit 0
