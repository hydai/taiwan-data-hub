# Node 22 matches package.json `engines.node >= 22`.
FROM node:22-bookworm-slim AS builder
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@10.13.1 --activate

# Workspace manifests first so `pnpm install` layers cache nicely.
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY web/package.json web/

RUN pnpm install --frozen-lockfile

COPY web web

RUN pnpm --filter web build

# Runtime — copy the build output AND the resolved node_modules from
# builder. adapter-node's build/ imports svelte's runtime from
# node_modules, so we can't ship build/ alone. We don't re-run
# `pnpm install --prod` because the project keeps all deps in
# devDependencies (sv-create default), so a prod install would
# resolve to zero packages and the svelte runtime would be missing.
# Multi-stage size optimization (pruning dev deps, distroless runtime)
# is deferred until we have a publishable image story.
FROM node:22-bookworm-slim AS runtime
WORKDIR /app
RUN useradd --system --uid 10003 --no-create-home --shell /usr/sbin/nologin tdh

# Bring the resolved deps. pnpm uses a symlinked node_modules layout
# (.pnpm/ store with symlinks) so we must copy both the workspace and
# package-level node_modules to preserve the link graph.
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/web/node_modules ./web/node_modules
COPY --from=builder /app/web/build ./web/build
COPY --from=builder /app/web/package.json ./web/

USER tdh:tdh
WORKDIR /app/web
EXPOSE 3000
ENV NODE_ENV=production
ENV PORT=3000
ENV HOST=0.0.0.0
CMD ["node", "build/index.js"]
